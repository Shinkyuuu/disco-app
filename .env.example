# Copy to .env and fill in values — never commit .env itself.
DISCORD_APPLICATION_ID=
DISCORD_PUBLIC_KEY=
DISCORD_BOT_TOKEN=
DISCORD_SERVER_ID=
DISCORD_CLIENT_SECRET=
DEEPGRAM_API_KEY=
