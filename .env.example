# Copy to .env and fill in values - never commit .env itself.

# Discord bot application - https://discord.com/developers/applications
DISCORD_APPLICATION_ID=
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_SECRET=

# Deepgram (speech-to-text) - https://console.deepgram.com
DEEPGRAM_API_KEY=

# MAX_ACTIVE_SESSIONS - optional, defaults to 5. Global cap on simultaneous active
# /disco join sessions across all guilds combined (cost control for Deepgram usage).
MAX_ACTIVE_SESSIONS=

# PORT - optional, defaults to 3000
PORT=

# PUBLIC_BASE_URL - hosted-deployment only, e.g. https://captions.yourdomain.com; leave unset for local dev.
# Must exactly match your Cloudflare Tunnel hostname and the redirect URI registered in the
# Discord Developer Portal.
PUBLIC_BASE_URL=

# SESSION_SECRET - required. Signs session tokens; generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Changing this value invalidates every existing session (everyone gets logged out).
SESSION_SECRET=

# AWS S3 + CloudFront (broadcast avatars) - see docs/superpowers/specs/2026-07-14-broadcast-avatar-design.md
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY are read automatically by the AWS SDK's
# default credential provider chain - only AWS_REGION needs to be passed explicitly.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
S3_AVATAR_BUCKET=
AVATAR_CDN_BASE_URL=   # e.g. https://d1234abcd.cloudfront.net - no trailing slash
